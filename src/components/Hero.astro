---
import { PROJECTS } from "../lib/site";

// Hero rotation: välj 4 representativa projekt från olika kategorier
const heroSlugs = ["rocmore-signalisten", "kvarteret-persikan", "vindarnas-tempel", "axfood-huvudkontor"];
const heroProjects = heroSlugs
  .map((slug) => PROJECTS.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<section class="relative overflow-hidden bg-[color:var(--color-paper)]">
  <div class="relative mx-auto max-w-7xl px-6 lg:px-10 pt-14 lg:pt-24 pb-16 lg:pb-28">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 bg-[color:var(--color-paper-2)] border border-[color:var(--color-ink-10)] rounded-full px-3.5 py-1.5 text-[11px] font-medium text-[color:var(--color-ink-60)] mb-8 tracking-wide fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-brand-red)]" aria-hidden="true"></span>
          Skyddsrum · Komplex entreprenad · Stockholm & Mälardalen
        </div>

        <h1 class="text-[length:var(--text-hero)] font-semibold leading-[0.95] tracking-tight mb-8 fade-in" style="animation-delay: 80ms">
          Projekt där andra tackar nej.
          <span class="block text-[color:var(--color-brand-red)]">Levererade med precision.</span>
        </h1>

        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-xl mb-10 fade-in" style="animation-delay: 160ms">
          Vi är specialister på skyddsrumssanering, skyddsrumsbesiktning och komplexa byggprojekt –
          från MSB-kontroll och åtgärdsplan till färdigt, godkänt skyddsrum. Kärnteamet bär
          <strong class="text-[color:var(--color-ink)] font-semibold">över 100 års samlad branscherfarenhet</strong>,
          och vi driver totalentreprenader med egen projektledning, egna hantverkare och beprövade underentreprenörer.
        </p>

        <div class="flex flex-wrap items-center gap-4 fade-in" style="animation-delay: 240ms">
          <a
            href="/kontakt"
            class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-white px-6 py-3.5 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] transition-colors"
          >
            Begär offert
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/projekt"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full text-sm font-semibold border border-[color:var(--color-ink)] text-[color:var(--color-ink)] hover:bg-[color:var(--color-ink)] hover:text-white transition-colors"
          >
            Se referensprojekt
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 fade-in" style="animation-delay: 320ms">
        <div
          id="hero-gallery"
          class="relative aspect-[4/5] rounded-3xl overflow-hidden bg-[color:var(--color-steel)] shadow-2xl shadow-black/10"
          aria-roledescription="bildkarusell"
          aria-label="Referensprojekt"
        >
          {heroProjects.map((p, i) => (
            <div
              class="hero-slide absolute inset-0"
              style={`display: ${i === 0 ? "block" : "none"};`}
              data-slide={i}
              aria-hidden={i === 0 ? "false" : "true"}
            >
              <img
                src={p.image}
                alt={p.imageAlt ?? p.title}
                loading={i === 0 ? "eager" : "lazy"}
                fetchpriority={i === 0 ? "high" : "auto"}
                decoding="async"
                class="hero-slide-img absolute inset-0 w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
              <div class="absolute bottom-6 left-6 right-6 text-white">
                <p class="text-[10px] uppercase tracking-[0.22em] text-white/60 mb-2 font-semibold">{i === 0 ? "Pågående projekt" : "Referensprojekt"}</p>
                <p class="text-lg font-semibold mb-1 leading-tight">{p.title}</p>
                <p class="text-sm text-white/70">{p.client}{p.volume ? ` · ${p.volume}` : ""}</p>
              </div>
            </div>
          ))}

          <!-- Indikator-prickar -->
          <div class="absolute top-5 right-5 flex gap-1.5" role="tablist" aria-label="Välj bild">
            {heroProjects.map((_, i) => (
              <button
                type="button"
                class="hero-dot h-1.5 rounded-full transition-all duration-300 hover:!bg-white/70"
                style={`width: ${i === 0 ? 24 : 6}px; background: ${i === 0 ? "rgb(255,255,255)" : "rgba(255,255,255,0.4)"};`}
                data-dot={i}
                role="tab"
                aria-selected={i === 0 ? "true" : "false"}
                aria-label={`Bild ${i + 1}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Trust-row: visar kundlogos ovanför fold -->
    <div class="mt-16 lg:mt-20 pt-8 border-t border-[color:var(--color-ink-10)] fade-in" style="animation-delay: 360ms">
      <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-ink-40)] font-semibold mb-6">Förtroende från krävande beställare</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-x-8 gap-y-6 items-center">
        <img src="/clients/locum.svg" alt="Locum AB" loading="eager" decoding="async" class="max-h-6 lg:max-h-7 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/stockholmshem.svg" alt="Stockholmshem" loading="eager" decoding="async" class="max-h-6 lg:max-h-7 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/octapharma.svg" alt="Octapharma" loading="eager" decoding="async" class="max-h-6 lg:max-h-7 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/lidingo-stad.svg" alt="Lidingö Stad" loading="eager" decoding="async" class="max-h-7 lg:max-h-9 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/axfood.svg" alt="Axfood" loading="eager" decoding="async" class="max-h-5 lg:max-h-6 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/skanska.svg" alt="Skanska" loading="eager" decoding="async" class="max-h-5 lg:max-h-6 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
        <img src="/clients/atrium.svg" alt="Atrium Ljungberg" loading="eager" decoding="async" class="max-h-5 lg:max-h-6 w-auto object-contain object-left [filter:brightness(0)] opacity-50 hover:opacity-100 hover:[filter:none] transition-all duration-300" />
      </div>
    </div>

    <!-- Nyckeltal -->
    <dl class="mt-14 lg:mt-16 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="fade-in" style="animation-delay: 400ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Branscherfarenhet i kärnteamet</dt>
        <dd class="text-4xl lg:text-6xl font-semibold tabular-nums leading-[1] tracking-tight">100<span class="text-[color:var(--color-brand-red)]">+</span> år</dd>
      </div>
      <div class="fade-in" style="animation-delay: 440ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Soliditet</dt>
        <dd class="text-4xl lg:text-6xl font-semibold tabular-nums leading-[1] tracking-tight">96 <span class="text-[color:var(--color-brand-red)]">%</span></dd>
      </div>
      <div class="fade-in" style="animation-delay: 480ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Största projekt</dt>
        <dd class="text-4xl lg:text-6xl font-semibold tabular-nums leading-[1] tracking-tight">75 <span class="text-[color:var(--color-brand-red)]">Mkr</span></dd>
      </div>
      <div class="fade-in" style="animation-delay: 520ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Projekt levererade sedan 2018</dt>
        <dd class="text-4xl lg:text-6xl font-semibold tabular-nums leading-[1] tracking-tight">40<span class="text-[color:var(--color-brand-red)]">+</span></dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .hero-slide-img {
    animation: kenBurns 14s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes kenBurns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.08) translate(-1%, 1%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide-img { animation: none !important; }
    .hero-slide { transition: none !important; }
  }
</style>

<script>
  (() => {
    const gallery = document.getElementById("hero-gallery");
    if (!gallery) return;
    const slides = Array.from(gallery.querySelectorAll<HTMLElement>(".hero-slide"));
    const dots = Array.from(gallery.querySelectorAll<HTMLElement>(".hero-dot"));
    if (slides.length < 2) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function show(next: number) {
      if (next === current) return;
      slides[current].style.display = "none";
      slides[current].setAttribute("aria-hidden", "true");
      slides[next].style.display = "block";
      slides[next].setAttribute("aria-hidden", "false");

      if (dots[current]) {
        dots[current].style.background = "rgba(255,255,255,0.4)";
        dots[current].style.width = "6px";
        dots[current].setAttribute("aria-selected", "false");
      }
      if (dots[next]) {
        dots[next].style.background = "rgb(255,255,255)";
        dots[next].style.width = "24px";
        dots[next].setAttribute("aria-selected", "true");
      }

      current = next;
    }

    function start() {
      stop();
      timer = setInterval(() => show((current + 1) % slides.length), 7000);
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    dots.forEach((d, i) => {
      d.addEventListener("click", () => {
        show(i);
        start();
      });
    });

    gallery.addEventListener("mouseenter", stop);
    gallery.addEventListener("mouseleave", start);
    gallery.addEventListener("focusin", stop);
    gallery.addEventListener("focusout", start);

    start();
  })();
</script>
