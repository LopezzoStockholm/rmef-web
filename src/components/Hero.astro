---
import { SITE, CLIENTS, PROJECTS } from "../lib/site";
const heroImage = PROJECTS[0]?.image ?? "/projekt/foretag_2.webp";
---

<section class="relative overflow-hidden bg-[color:var(--color-paper)]">
  <!-- Splitlayout: vänster = text, höger = bild (desktop). Stackat på mobil. -->
  <div class="relative mx-auto max-w-7xl px-6 lg:px-10 pt-14 lg:pt-24 pb-16 lg:pb-28">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 bg-[color:var(--color-paper-2)] border border-[color:var(--color-ink-10)] rounded-full px-3.5 py-1.5 text-[11px] font-medium text-[color:var(--color-ink-60)] mb-8 tracking-wide fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-brand-red)]" aria-hidden="true"></span>
          Totalentreprenad i Stockholm sedan 2020
        </div>

        <h1 class="text-[length:var(--text-hero)] font-semibold leading-[0.95] tracking-tight mb-8 fade-in" style="animation-delay: 80ms">
          Bygger Stockholm
          <span class="block text-[color:var(--color-brand-red)]">från grund till fasad.</span>
        </h1>

        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-xl mb-10 fade-in" style="animation-delay: 160ms">
          Mark. Bygg. El. Fasad. Fyra discipliner, en kontakt, hela vägen till driftklar anläggning.
          Vi jobbar B2B med beställare som har höga krav på kvalitet, precision och leverans i tid.
        </p>

        <div class="flex flex-wrap items-center gap-4 fade-in" style="animation-delay: 240ms">
          <a
            href="/kontakt"
            class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-white px-6 py-3.5 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] transition-colors"
          >
            Begär offert
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/projekt"
            class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full text-sm font-semibold border border-[color:var(--color-ink)] text-[color:var(--color-ink)] hover:bg-[color:var(--color-ink)] hover:text-white transition-colors"
          >
            Se referensprojekt
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 fade-in" style="animation-delay: 320ms">
        <div class="relative aspect-[4/5] rounded-3xl overflow-hidden bg-[color:var(--color-steel)] shadow-2xl shadow-black/10">
          <img
            src={heroImage}
            alt="Pågående projekt — RM Entreprenad & Fasad"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6 text-white">
            <p class="text-[10px] uppercase tracking-[0.2em] text-white/60 mb-2">Pågående projekt</p>
            <p class="text-lg font-semibold">Kvarteret Persikan</p>
            <p class="text-sm text-white/70">Stockholmshem · 75 Mkr</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Nyckeltal -->
    <dl class="mt-20 lg:mt-24 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 border-t border-[color:var(--color-ink-10)] pt-10">
      <div class="fade-in" style="animation-delay: 400ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Omsättning senaste år</dt>
        <dd class="text-3xl lg:text-4xl font-semibold tabular-nums">14,7 Mkr</dd>
      </div>
      <div class="fade-in" style="animation-delay: 440ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Soliditet</dt>
        <dd class="text-3xl lg:text-4xl font-semibold tabular-nums">96 %</dd>
      </div>
      <div class="fade-in" style="animation-delay: 480ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Största projekt</dt>
        <dd class="text-3xl lg:text-4xl font-semibold tabular-nums">75 Mkr</dd>
      </div>
      <div class="fade-in" style="animation-delay: 520ms">
        <dt class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Erfarenhet i teamet</dt>
        <dd class="text-3xl lg:text-4xl font-semibold tabular-nums">15+ år</dd>
      </div>
    </dl>
  </div>

  <!-- Kundlogos-marquee -->
  <div class="border-y border-[color:var(--color-ink-10)] bg-[color:var(--color-paper-2)]/60 py-6 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 mb-4">
      <p class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-ink-40)] font-semibold">
        Vi levererar till
      </p>
    </div>
    <div class="overflow-hidden">
      <div class="marquee text-xl lg:text-2xl font-semibold text-[color:var(--color-ink-40)]">
        {CLIENTS.concat(CLIENTS).map((c) => (
          <span class="flex items-center gap-12">
            {c}
            <span class="w-1 h-1 rounded-full bg-[color:var(--color-brand-red)]" aria-hidden="true"></span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
