---
// Kundlogotyper grupperade per sektor.
// Varje kund kan ha en /clients/{slug}.svg-fil i public/. Om filen saknas
// renderas en designad textmark istället. När du har officiella SVG-logos:
// 1. Lägg dem i public/clients/{slug}.svg (200x48 viewBox, currentColor fyllning)
// 2. Sätt useImage: true på objektet nedan

type Client = {
  name: string;
  slug: string;
  href?: string;
  note?: string;
  style: "sans" | "serif" | "bold" | "italic";
  useImage?: boolean;
};

type Category = {
  label: string;
  clients: Client[];
};

const categories: Category[] = [
  {
    label: "Kommun & offentlig sektor",
    clients: [
      { name: "Locum AB", slug: "locum", style: "sans", note: "Region Stockholms fastighetsbolag", useImage: true },
      { name: "Lidingö Stad", slug: "lidingo-stad", style: "serif", note: "Antikvariska restaureringar", useImage: true },
      { name: "Solna Stad", slug: "solna-stad", style: "sans", note: "Skol- och institutionsbygg", useImage: true },
      { name: "Sigtuna kommun", slug: "sigtuna", style: "sans", note: "Engelska skolan Sigtuna", useImage: true },
    ],
  },
  {
    label: "Allmännytta & bostadsbolag",
    clients: [
      { name: "Stockholmshem", slug: "stockholmshem", style: "serif", note: "75 Mkr grundläggning Persikan", useImage: true },
      { name: "Signalisten", slug: "signalisten", style: "sans", note: "Ramavtal Solna", useImage: true },
      { name: "Atrium Ljungberg", slug: "atrium", style: "sans", note: "Kontorsfastigheter", useImage: true },
    ],
  },
  {
    label: "Privata fastighetsbolag & industri",
    clients: [
      { name: "Octapharma", slug: "octapharma", style: "sans", note: "Läkemedelsproduktion", useImage: true },
      { name: "Axfood", slug: "axfood", style: "bold", note: "Huvudkontor 3 000 kvm", useImage: true },
      { name: "Patriam", slug: "patriam", style: "italic", note: "Stocksund nyproduktion", useImage: true },
      { name: "Skanska", slug: "skanska", style: "bold", note: "Underentreprenad", useImage: true },
      { name: "Habitek", slug: "habitek", style: "bold", note: "Totalentreprenad", useImage: true },
      { name: "Rocmore", slug: "rocmore", style: "italic", note: "Strategisk partner" },
    ],
  },
];

const styleClass: Record<Client["style"], string> = {
  serif: "font-serif italic tracking-tight text-[color:var(--color-ink)]",
  sans: "font-medium tracking-tight text-[color:var(--color-ink)]",
  bold: "font-bold tracking-[-0.025em] text-[color:var(--color-ink)]",
  italic: "font-serif italic tracking-tight text-[color:var(--color-ink)]",
};
---

<section class="py-20 lg:py-28 border-y border-[color:var(--color-ink-10)] bg-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <!-- Header -->
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 mb-16 lg:mb-20">
      <div class="lg:col-span-7">
        <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-4">Utvalda beställare</p>
        <h2 class="text-3xl lg:text-5xl font-semibold tracking-tight leading-[1.05] max-w-3xl">
          Vi är leverantör åt några av Sveriges mest krävande beställare.
        </h2>
      </div>
      <div class="lg:col-span-5 lg:pt-4 flex items-end">
        <p class="text-base lg:text-lg text-[color:var(--color-ink-60)] leading-relaxed">
          Region Stockholms sjukhus, kommunala bolag, börsnoterade fastighetsägare och läkemedelsproduktion. Gemensamt: höga krav på precision, säkerhet och förutsägbarhet.
        </p>
      </div>
    </div>

    <!-- Categories with logos -->
    <div class="space-y-14 lg:space-y-16">
      {categories.map((category) => (
        <div>
          <div class="flex items-center gap-3 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-brand-red)]" aria-hidden="true"></span>
            <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-ink-60)] font-semibold">
              {category.label}
            </p>
            <span class="flex-1 h-px bg-[color:var(--color-ink-10)]" aria-hidden="true"></span>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-8">
            {category.clients.map((c) => (
              <div class="group relative pb-4 border-b border-[color:var(--color-ink-10)] hover:border-[color:var(--color-brand-red)] transition-colors">
                <div class="h-10 lg:h-11 flex items-center">
                  {c.useImage ? (
                    <img
                      src={`/clients/${c.slug}.svg`}
                      alt={c.name}
                      width="160"
                      height="40"
                      class="max-h-9 lg:max-h-10 w-auto object-contain object-left [filter:brightness(0)] opacity-55 group-hover:opacity-100 group-hover:[filter:none] transition-all duration-300"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class={`block text-lg lg:text-xl ${styleClass[c.style]} opacity-70 group-hover:opacity-100 transition-opacity`}>
                      {c.name}
                    </span>
                  )}
                </div>
                {c.note && (
                  <span class="block text-xs text-[color:var(--color-ink-40)] mt-2 group-hover:text-[color:var(--color-brand-red)] transition-colors">
                    {c.note}
                  </span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="mt-16 lg:mt-20 pt-10 border-t border-[color:var(--color-ink-10)] flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <p class="text-base text-[color:var(--color-ink-60)] max-w-xl leading-relaxed">
        Tio av tretton listade kunder är återkommande beställare med ramavtal eller flera levererade projekt. Förtroendet växer projekt för projekt.
      </p>
      <a
        href="/projekt"
        class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-red)] transition-colors whitespace-nowrap"
      >
        Se samtliga referensprojekt
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
