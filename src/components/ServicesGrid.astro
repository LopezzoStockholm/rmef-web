---
import { SERVICES } from "../lib/site";

// Representativa projektbilder per disciplin
const serviceImages: Record<string, { src: string; alt: string }> = {
  mark: {
    src: "/projekt/thumb/mark_image6.webp",
    alt: "Markarbete med betongpump på Solnaprojekt",
  },
  bygg: {
    src: "/projekt/thumb/foretag_4.webp",
    alt: "Axfoods huvudkontor, kontorsanpassning",
  },
  el: {
    src: "/projekt/thumb/foretag_15.webp",
    alt: "Elinstallation T11 Katarinahuset",
  },
  fasad: {
    src: "/projekt/thumb/bygg_image4.webp",
    alt: "Vindarnas tempel, antikvarisk fasadrestaurering",
  },
};
---

<section class="py-20 lg:py-32 bg-[color:var(--color-paper)]">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="max-w-3xl mb-16 lg:mb-20">
      <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-4">Tjänster</p>
      <h2 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight mb-6">
        Fyra discipliner. Ett ansvar.
      </h2>
      <p class="text-lg text-[color:var(--color-ink-60)] leading-relaxed">
        Vi täcker hela entreprenadkedjan i egen regi, från mark under fasaden till ljuset i taket.
        Det gör att vi kan styra kvalitet, tid och budget utan mellanhänder.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 lg:gap-6">
      {
        Object.values(SERVICES).map((service, idx) => (
          <a
            href={`/tjanster/${service.slug}`}
            class="group relative overflow-hidden bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500"
          >
            <div class="relative aspect-[16/9] overflow-hidden bg-[color:var(--color-steel)]">
              <img
                src={serviceImages[service.icon]?.src ?? "/projekt/thumb/mark_image6.webp"}
                alt={serviceImages[service.icon]?.alt ?? service.title}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/15 to-transparent group-hover:from-black/80 transition-colors duration-500"></div>
              <span class="absolute top-5 right-5 text-xs uppercase tracking-[0.2em] text-white/70 font-semibold">
                0{idx + 1}
              </span>
              <span class="absolute top-5 left-5 inline-flex items-center gap-2 bg-[color:var(--color-brand-red)] text-white px-3 py-1 rounded-full text-[10px] uppercase tracking-wider font-semibold">
                Disciplin
              </span>
            </div>

            <div class="p-8 lg:p-10">
              <h3 class="text-2xl lg:text-3xl font-semibold mb-3 tracking-tight">{service.title}</h3>
              <p class="text-[color:var(--color-ink-60)] group-hover:text-white/70 transition-colors leading-relaxed mb-6 line-clamp-2">
                {service.short}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-brand-red)] group-hover:text-white transition-colors">
                Läs mer
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                  <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
