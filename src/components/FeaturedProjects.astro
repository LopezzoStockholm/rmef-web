---
import { PROJECTS } from "../lib/site";
const featured = PROJECTS.filter((p) => p.featured);
---

<section class="py-20 lg:py-32 bg-[color:var(--color-asphalt)] text-white overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20 gap-6" data-reveal>
      <div class="max-w-2xl">
        <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-4">Utvalda referensprojekt</p>
        <h2 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight">
          Komplext. Levererat. Dokumenterat.
        </h2>
      </div>
      <a
        href="/projekt"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors"
      >
        Se samtliga 15 referensprojekt
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-6">
      {
        featured.map((p, idx) => (
          <a href={`/projekt/${p.slug}`} class="group block" data-reveal style={`transition-delay: ${idx * 80}ms`}>
            <div class="aspect-[4/5] rounded-2xl overflow-hidden relative mb-5 bg-gradient-to-br from-[color:var(--color-steel)] to-[#0a0a0a]">
              {p.image ? (
                <>
                  <img
                    src={p.image.replace('/projekt/', '/projekt/thumb/')}
                    alt={p.imageAlt ?? p.title}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/10 to-transparent"></div>
                </>
              ) : (
                <>
                  <div class="absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-35 group-hover:scale-110 transition-all duration-700" aria-hidden="true">
                    <svg width="180" height="180" viewBox="0 0 96 96" fill="none" stroke="#C8381F" stroke-width="0.8">
                      <path d="M8 80h80M12 80V40l20-16 20 16v40M52 80V32l20-16 12 10v54M20 80V56h12v24M60 80V48h12v32M24 48h4M24 60h4M64 56h4M64 64h4"/>
                    </svg>
                  </div>
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
                </>
              )}
              <div class="absolute top-5 left-5">
                <span class="text-[10px] uppercase tracking-[0.18em] bg-[color:var(--color-brand-red)] text-white px-3 py-1.5 rounded-full font-semibold">
                  {p.category}
                </span>
              </div>
              <div class="absolute bottom-5 left-5 right-5 text-white">
                <p class="text-[11px] uppercase tracking-[0.16em] text-white/60 mb-1 font-semibold">{p.client}</p>
                <p class="text-xs text-white/40">{p.period}</p>
              </div>
            </div>
            <div class="flex items-baseline justify-between gap-3 mb-2">
              <h3 class="text-lg lg:text-xl font-semibold tracking-tight group-hover:text-[color:var(--color-brand-red)] transition-colors">
                {p.title}
              </h3>
              {p.volume && (
                <span class="text-xs font-semibold text-[color:var(--color-brand-red)] whitespace-nowrap tabular-nums">{p.volume}</span>
              )}
            </div>
            <p class="text-sm text-white/55 leading-relaxed line-clamp-2">
              {p.summary}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
