---
import { PROJECTS } from "../lib/site";
const featured = PROJECTS.filter((p) => p.featured);
---

<section class="py-20 lg:py-32 bg-[color:var(--color-ink)] text-white overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20 gap-6">
      <div class="max-w-2xl">
        <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-4">Referensprojekt</p>
        <h2 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight">
          Komplext. Levererat.
        </h2>
      </div>
      <a
        href="/projekt"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors"
      >
        Se alla projekt
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        featured.map((p) => (
          <a href={`/projekt/${p.slug}`} class="group block">
            <div class="aspect-[4/5] bg-gradient-to-br from-[color:var(--color-steel)] to-[#1a1a1a] rounded-2xl overflow-hidden relative mb-6">
              <div class="absolute inset-0 flex items-center justify-center opacity-20 group-hover:opacity-40 group-hover:scale-110 transition-all duration-700">
                <svg width="200" height="200" viewBox="0 0 96 96" fill="none" stroke="white" stroke-width="1" aria-hidden="true">
                  <path d="M8 80h80M12 80V40l20-16 20 16v40M52 80V32l20-16 12 10v54M20 80V56h12v24M60 80V48h12v32M24 48h4M24 60h4M64 56h4M64 64h4"/>
                </svg>
              </div>
              <div class="absolute top-6 left-6 flex items-center gap-3">
                <span class="text-xs uppercase tracking-wider bg-[color:var(--color-brand-red)] text-white px-3 py-1 rounded-full font-semibold">
                  {p.category}
                </span>
              </div>
              <div class="absolute bottom-6 left-6 right-6">
                <p class="text-sm text-white/60">{p.client}</p>
                <p class="text-sm text-white/40">{p.period}</p>
              </div>
            </div>
            <div class="flex items-baseline justify-between mb-3">
              <h3 class="text-xl lg:text-2xl font-semibold tracking-tight group-hover:text-[color:var(--color-brand-red)] transition-colors">
                {p.title}
              </h3>
              <span class="text-sm font-semibold text-[color:var(--color-brand-red)]">{p.volume}</span>
            </div>
            <p class="text-sm text-white/60 leading-relaxed line-clamp-3">
              {p.summary}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
