---
import { PROJECTS } from "../lib/site";
const featured = PROJECTS.filter((p) => p.featured);
---

<section class="py-20 lg:py-32 bg-[color:var(--color-asphalt)] text-white overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-16 lg:mb-20 gap-6">
      <div class="max-w-2xl">
        <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-brand-red)] font-semibold mb-4">Referensprojekt</p>
        <h2 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight">
          Komplext. Levererat.
        </h2>
      </div>
      <a
        href="/projekt"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors"
      >
        Se alla projekt
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-6">
      {
        featured.map((p) => (
          <a href={`/projekt/${p.slug}`} class="group block">
            <div class="aspect-[4/5] rounded-2xl overflow-hidden relative mb-5 bg-[color:var(--color-steel)]">
              <img
                src={p.image.replace('/projekt/', '/projekt/thumb/')}
                alt={p.imageAlt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
              <div class="absolute top-5 left-5">
                <span class="text-[10px] uppercase tracking-[0.18em] bg-[color:var(--color-brand-red)] text-white px-3 py-1.5 rounded-full font-semibold">
                  {p.category}
                </span>
              </div>
              <div class="absolute bottom-5 left-5 right-5 text-white">
                <p class="text-xs uppercase tracking-[0.12em] text-white/60 mb-1">{p.client}</p>
                <p class="text-xs text-white/40">{p.period}</p>
              </div>
            </div>
            <div class="flex items-baseline justify-between gap-3 mb-2">
              <h3 class="text-lg lg:text-xl font-semibold tracking-tight group-hover:text-[color:var(--color-brand-red)] transition-colors">
                {p.title}
              </h3>
              <span class="text-xs font-semibold text-[color:var(--color-brand-red)] whitespace-nowrap">{p.volume}</span>
            </div>
            <p class="text-sm text-white/55 leading-relaxed line-clamp-2">
              {p.summary}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
