---
import { SITE, SERVICES } from "../lib/site";

const year = new Date().getFullYear();
---

<footer class="bg-[color:var(--color-asphalt)] text-white mt-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-10 py-16 lg:py-24">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-12">
      <div class="col-span-2 lg:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center">
            <span class="text-[color:var(--color-brand-red)] font-bold text-base">RM</span>
          </div>
          <span class="font-semibold text-sm">RM Entreprenad<br />& Fasad AB</span>
        </div>
        <p class="text-sm text-white/60 leading-relaxed max-w-sm mb-6">
          Stockholmsbaserat entreprenadbolag som levererar total- och utförandeentreprenader
          inom mark, bygg, el och fasad åt professionella beställare.
        </p>
        <div class="flex flex-wrap gap-2 text-[10px] font-semibold uppercase tracking-[0.15em]">
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Godkänd F-skatt</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Momsregistrerad</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Ansvarsförsäkring</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">ID06</span>
        </div>
      </div>

      <div>
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-4">Tjänster</h3>
        <ul class="space-y-3 text-sm">
          {
            Object.values(SERVICES).map((s) => (
              <li>
                <a href={`/tjanster/${s.slug}`} class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">
                  {s.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-4">Företag</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/projekt" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Referensprojekt</a></li>
          <li><a href="/artiklar" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Artiklar och guider</a></li>
          <li><a href="/om-oss" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Om oss</a></li>
          <li><a href="/karriar" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Karriär</a></li>
          <li><a href="/kontakt" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-4">Kontakt</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:${SITE.phoneDisplay.replace(/\s/g, "")}`} class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">
              {SITE.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">
              {SITE.email}
            </a>
          </li>
          <li class="text-white/60 pt-1">
            {SITE.address.city}, Sverige
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 grid lg:grid-cols-3 gap-6 text-xs text-white/50">
      <div>
        <p class="text-white/70 font-semibold mb-1">RM Entreprenad & Fasad AB</p>
        <p>Org.nr {SITE.orgNumber}</p>
        <p>Säte: Stockholm</p>
      </div>
      <div>
        <p class="text-white/70 font-semibold mb-1">Juridisk information</p>
        <p>VD: {SITE.vd}</p>
        <p>Ansvarsförsäkring: {SITE.insurance}</p>
      </div>
      <div class="lg:text-right">
        <p>© {year} {SITE.name}</p>
        <p class="flex flex-wrap gap-x-3 gap-y-1 lg:justify-end mt-2">
          <a href="/integritetspolicy/" class="hover:text-white transition-colors">Integritetspolicy</a>
          <span class="text-white/30">·</span>
          <a href="/cookies/" class="hover:text-white transition-colors">Cookies</a>
        </p>
      </div>
    </div>
  </div>
</footer>
