---
import { SITE, SERVICES } from "../lib/site";

const year = new Date().getFullYear();
---

<footer class="bg-[color:var(--color-asphalt)] text-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <!-- Top: mini-CTA -->
    <div class="border-b border-white/10 py-12 lg:py-16">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-3">Påbörja ett projekt</p>
          <h3 class="text-2xl lg:text-3xl font-semibold tracking-tight max-w-2xl leading-tight">
            Vi svarar samma dag och ger besked inom 48 timmar.
          </h3>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="/kontakt"
            class="inline-flex items-center gap-2 bg-white text-[color:var(--color-ink)] px-5 py-3 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] hover:text-white transition-colors"
          >
            Begär offert
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={`tel:${SITE.phoneDisplay.replace(/\s/g, "")}`}
            class="inline-flex items-center gap-2 border border-white/20 text-white px-5 py-3 rounded-full text-sm font-semibold hover:bg-white/5 hover:border-white/40 transition-colors"
          >
            {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>

    <!-- Mid: links + info -->
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-12 py-16 lg:py-20">
      <div class="col-span-2 lg:col-span-4">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/logo.svg" alt={SITE.name} width="180" height="44" class="h-10 w-auto" style="filter: invert(1) brightness(2);" />
        </a>
        <p class="text-sm text-white/60 leading-relaxed max-w-sm mb-6">
          Specialister på skyddsrum och komplex entreprenad i Stockholm och Mälardalen.
          Egen projektledning, egna hantverkare, beprövade underentreprenörer.
        </p>
        <div class="flex flex-wrap gap-2 text-[10px] font-semibold uppercase tracking-[0.15em] mb-8">
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Godkänd F-skatt</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Momsregistrerad</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">Ansvarsförsäkring</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">ID06</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">ABT 06</span>
          <span class="bg-white/10 px-3 py-1.5 rounded-full">AB 04</span>
        </div>
        {SITE.socials.linkedin && (
          <a href={SITE.socials.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        )}
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-5">Tjänster</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/tjanster/skyddsrum/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Skyddsrum</a></li>
          <li><a href="/tjanster/betongrenovering/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Betongrenovering</a></li>
          <li><a href="/tjanster/restaurering-kulturbyggnad/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Restaurering K-märkt</a></li>
          <li><a href="/tjanster/ombyggnation/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Ombyggnation</a></li>
          {
            Object.values(SERVICES).map((s) => (
              <li>
                <a href={`/tjanster/${s.slug}`} class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">
                  {s.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-5">Lokalt</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/lokalt/skyddsrum-stockholm/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Skyddsrum Stockholm</a></li>
          <li><a href="/lokalt/fasadrenovering-lidingo/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Fasad Lidingö</a></li>
          <li><a href="/lokalt/fasadrenovering-solna/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Fasad Solna</a></li>
          <li><a href="/lokalt/betongrenovering-stockholm/" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Betong Stockholm</a></li>
          <li><a href="/lokalt/" class="text-white/60 hover:text-white transition-colors">Alla orter →</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-5">Företag</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/projekt" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Referensprojekt</a></li>
          <li><a href="/artiklar" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Artiklar</a></li>
          <li><a href="/om-oss" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Om oss</a></li>
          <li><a href="/karriar" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Karriär</a></li>
          <li><a href="/vanliga-fragor" class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors">Vanliga frågor</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-[10px] font-semibold uppercase tracking-[0.22em] text-white/40 mb-5">Kontakt</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:${SITE.phoneDisplay.replace(/\s/g, "")}`} class="text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors block">
              {SITE.phoneDisplay}
            </a>
          </li>
          <li>
            <a href="#" data-mail-user={SITE.email.split("@")[0]} data-mail-domain={SITE.email.split("@")[1]} class="email-link text-white/80 hover:text-[color:var(--color-brand-red)] transition-colors block break-all">
              {SITE.email.split("@")[0]}<span aria-hidden="true">[at]</span>{SITE.email.split("@")[1]}
            </a>
          </li>
          <li class="text-white/60 pt-1">
            {SITE.address.city}, Sverige
          </li>
          <li>
            <a href="/kontakt" class="inline-flex items-center gap-1.5 text-[color:var(--color-brand-red)] hover:text-white transition-colors text-sm font-semibold mt-3">
              Begär offert
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom: legal -->

    <script>
      // Konstruerar mailto: efter page load så CF inte injectar email-decode script
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll<HTMLAnchorElement>("a.email-link").forEach((a) => {
          const u = a.dataset.mailUser;
          const d = a.dataset.mailDomain;
          if (u && d) {
            a.href = `mailto:${u}@${d}`;
            a.textContent = `${u}@${d}`;
          }
        });
      });
    </script>
    <!-- /script -->
    <div class="border-t border-white/10 py-8 grid lg:grid-cols-3 gap-4 text-xs text-white/50">
      <div>
        <p class="text-white/70 font-semibold mb-1">{SITE.name}</p>
        <p>Org.nr {SITE.orgNumber} · Säte: Stockholm</p>
      </div>
      <div>
        <p class="text-white/70 font-semibold mb-1">Juridiskt</p>
        <p>VD: {SITE.vd} · Ansvarsförsäkring: {SITE.insurance}</p>
      </div>
      <div class="lg:text-right">
        <p>© {year} {SITE.name}</p>
        <p class="flex flex-wrap gap-x-3 gap-y-1 lg:justify-end mt-2">
          <a href="/integritetspolicy/" class="hover:text-white transition-colors">Integritetspolicy</a>
          <span class="text-white/30">·</span>
          <a href="/cookies/" class="hover:text-white transition-colors">Cookies</a>
        </p>
      </div>
    </div>
  </div>
</footer>
