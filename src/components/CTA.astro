---
import { SITE } from "../lib/site";
const msg = encodeURIComponent("Hej! Jag är intresserad av att diskutera ett projekt.");
const waLink = `https://wa.me/${SITE.whatsapp.replace(/\D/g, "")}?text=${msg}`;
---

<section class="py-20 lg:py-32 bg-[color:var(--color-paper)]">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="relative overflow-hidden rounded-3xl bg-[color:var(--color-ink)] text-white">
      <!-- Subtil bakgrundsdetalj: stora typografiska siffror -->
      <div class="absolute -right-10 -bottom-16 lg:-right-20 lg:-bottom-24 select-none pointer-events-none" aria-hidden="true">
        <span class="block text-[12rem] lg:text-[20rem] font-semibold leading-none tracking-tight text-white/[0.04]">
          48h
        </span>
      </div>

      <div class="relative grid lg:grid-cols-12 gap-10 p-10 lg:p-16 xl:p-20">
        <!-- Vänster: Headline + body -->
        <div class="lg:col-span-7">
          <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-5">Nästa steg</p>
          <h2 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight mb-6">
            Skicka underlag. Besked inom 48 timmar.
          </h2>
          <p class="text-lg lg:text-xl text-white/70 leading-relaxed max-w-xl">
            Vi återkommer samma dag. Inom 48 timmar får ni besked om vi är rätt partner, och en första kostnadsram om vi är det. En sak till: ingen underentreprenör får betalt innan ni godkänt leveransen enligt avtal. Ni har full kontroll på kassaflödet hela vägen.
          </p>
        </div>

        <!-- Höger: CTA-knappar och kontaktinfo -->
        <div class="lg:col-span-5 flex flex-col gap-3 lg:items-end lg:justify-center">
          <a
            href="/kontakt"
            class="inline-flex items-center justify-between gap-3 bg-white text-[color:var(--color-ink)] px-6 py-4 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] hover:text-white transition-colors w-full lg:w-auto lg:min-w-[280px]"
          >
            Begär offert
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href={`tel:${SITE.phoneDisplay.replace(/\s/g, "")}`}
            class="inline-flex items-center justify-between gap-3 bg-transparent border border-white/20 text-white px-6 py-4 rounded-full text-sm font-semibold hover:bg-white/5 hover:border-white/40 transition-colors w-full lg:w-auto lg:min-w-[280px]"
          >
            Ring {SITE.phoneDisplay}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M11.6 9.5l-1.4-.4c-.4-.1-.7-.0-1 .3l-.7.6c-1.1-.5-2-1.4-2.5-2.5l.6-.7c.3-.3.4-.6.3-1l-.4-1.4c-.1-.4-.5-.6-.9-.6H4.3c-.5 0-.9.4-.8.9.4 4 3.6 7.2 7.6 7.6.5.1.9-.3.9-.8v-.7c0-.4-.2-.8-.4-.9z" fill="currentColor"/>
            </svg>
          </a>
          <a
            href={waLink}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-sm font-medium text-white/60 hover:text-white transition-colors mt-2 lg:mt-1"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Eller skriv via WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
