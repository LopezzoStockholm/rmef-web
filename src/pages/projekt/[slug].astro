---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { PROJECTS, SITE } from "../../lib/site";

export function getStaticPaths() {
  return PROJECTS.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "Project",
  name: project.title,
  description: project.summary,
  provider: { "@id": `${SITE.url}/#organization` },
  client: project.client,
  image: `${SITE.url}${project.image}`,
  url: `${SITE.url}/projekt/${project.slug}`,
};

const otherProjects = PROJECTS.filter((p) => p.slug !== project.slug && p.category === project.category).slice(0, 3);

// Mappning från projekt-kategori till primär tjänstesida för internlänk.
// Money-page-länkar: case bör peka tillbaka till tjänsten de exemplifierar.
const categoryToService: Record<string, { slug: string; name: string }> = {
  "Projektering": { slug: "projektering", name: "Projektering inhouse" },
  "Mark & anläggning": { slug: "mark-och-anlaggning", name: "Mark och anläggning" },
  "Bygg": { slug: "bygg", name: "Bygg och totalentreprenad" },
  "Fasad": { slug: "fasad", name: "Fasadrenovering" },
};
const primaryService = categoryToService[project.category];
---

<BaseLayout
  title={project.title}
  description={project.summary.slice(0, 155)}
  image={project.image}
  schema={projectSchema}
>
  <article>
    <section class="pt-24 lg:pt-32 pb-8 lg:pb-12">
      <div class="mx-auto max-w-5xl px-6 lg:px-10">
        <nav class="text-xs text-[color:var(--color-ink-40)] mb-8" aria-label="Brödsmulor">
          <a href="/" class="hover:text-[color:var(--color-brand-red)]">Hem</a>
          <span class="mx-2">/</span>
          <a href="/projekt" class="hover:text-[color:var(--color-brand-red)]">Referensprojekt</a>
          <span class="mx-2">/</span>
          <span>{project.title}</span>
        </nav>

        <span class="text-[10px] uppercase tracking-[0.2em] bg-[color:var(--color-brand-red)] text-white px-3 py-1.5 rounded-full font-semibold">
          {project.category}
        </span>
        <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight mt-6 mb-8">
          {project.title}
        </h1>

        <dl class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 pt-8 border-t border-[color:var(--color-ink-10)]">
          <div>
            <dt class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Beställare</dt>
            <dd class="text-base font-semibold">{project.client}</dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Period</dt>
            <dd class="text-base font-semibold">{project.period}</dd>
          </div>
          <div>
            <dt class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Entreprenadform</dt>
            <dd class="text-base font-semibold">{project.type}</dd>
          </div>
          {project.volume && (
            <div>
              <dt class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] mb-2 font-semibold">Projektvolym</dt>
              <dd class="text-base font-semibold">{project.volume}</dd>
            </div>
          )}
        </dl>
      </div>
    </section>

    {project.image && (
      <section class="pb-12 lg:pb-20">
        <div class="mx-auto max-w-6xl px-6 lg:px-10">
          <div class="aspect-[16/9] rounded-3xl overflow-hidden bg-[color:var(--color-steel)]">
            <img
              src={project.image}
              alt={project.imageAlt ?? project.title}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </section>
    )}

    <section class="pb-20 lg:pb-32">
      <div class="mx-auto max-w-3xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-6">Uppdraget</h2>
        <p class="text-lg text-[color:var(--color-ink-60)] leading-relaxed mb-12">
          {project.summary}
        </p>

        {project.challenges && (
          <>
            <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-6">Utmaningar</h2>
            <p class="text-lg text-[color:var(--color-ink-60)] leading-relaxed mb-12">
              {project.challenges}
            </p>
          </>
        )}

        {primaryService && (
          <div class="mt-8 pt-8 border-t border-[color:var(--color-ink-10)]">
            <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-ink-40)] font-semibold mb-4">Tjänst i detta projekt</p>
            <div class="flex flex-wrap items-center gap-4">
              <a href={`/tjanster/${primaryService.slug}/`} class="inline-flex items-center gap-2 bg-[color:var(--color-ink)] text-white px-5 py-3 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] transition-colors">
                {primaryService.name}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a href="/systemet" class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-red)] transition-colors">
                Hur vi arbetar: Systemet
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        )}
      </div>
    </section>

    {otherProjects.length > 0 && (
      <section class="pb-20 lg:pb-32 bg-[color:var(--color-paper-2)] pt-20 lg:pt-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Fler projekt inom {project.category.toLowerCase()}</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {otherProjects.map((p) => (
              <a href={`/projekt/${p.slug}`} class="group block">
                <div class="aspect-[4/3] rounded-2xl overflow-hidden relative mb-4 bg-gradient-to-br from-[color:var(--color-steel)] to-[#0a0a0a]">
                  {p.image ? (
                    <>
                      <img src={p.image.replace('/projekt/', '/projekt/thumb/')} alt={p.imageAlt ?? p.title} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"/>
                      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    </>
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center opacity-25" aria-hidden="true">
                      <svg width="120" height="120" viewBox="0 0 96 96" fill="none" stroke="#C8381F" stroke-width="0.7">
                        <path d="M8 80h80M12 80V40l20-16 20 16v40M52 80V32l20-16 12 10v54M20 80V56h12v24M60 80V48h12v32"/>
                      </svg>
                    </div>
                  )}
                </div>
                <h3 class="text-lg font-semibold tracking-tight group-hover:text-[color:var(--color-brand-red)] transition-colors">{p.title}</h3>
                <p class="text-sm text-[color:var(--color-ink-60)]">{p.client}{p.volume ? ` · ${p.volume}` : ''}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CTA />
  </article>
</BaseLayout>
