---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { PROJECTS } from "../../lib/site";

const categories = Array.from(new Set(PROJECTS.map((p) => p.category)));
---

<BaseLayout
  title="Referensprojekt"
  description="Utvalda projekt från RM Entreprenad & Fasad — grundläggning för Stockholmshem 75 Mkr, totalombyggnad Axfood, restaurering av K-märkta byggnader på Lidingö."
>
  <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-6">Referensprojekt</p>
      <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
        Från kulturhistorisk restaurering till industriell grundläggning.
      </h1>
      <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
        Ett urval av projekt som teamet bakom RM Entreprenad & Fasad levererat åt Stockholmshem,
        Atrium Ljungberg, Skanska, Axfood, Locum, Lidingö Stad och flera kommuner.
        Samtliga uppdrag är utförda enligt AB 04 eller ABT 06 med dokumenterad KMA-plan.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="flex flex-wrap gap-2 mb-12" role="tablist" aria-label="Filtrera projekt">
        <button data-filter="all" class="filter-btn active bg-[color:var(--color-ink)] text-white px-4 py-2 rounded-full text-sm font-medium transition-colors" role="tab" aria-selected="true">
          Alla ({PROJECTS.length})
        </button>
        {
          categories.map((c) => {
            const count = PROJECTS.filter((p) => p.category === c).length;
            return (
              <button data-filter={c} class="filter-btn bg-[color:var(--color-paper-2)] text-[color:var(--color-ink)] px-4 py-2 rounded-full text-sm font-medium hover:bg-[color:var(--color-ink)] hover:text-white transition-colors" role="tab" aria-selected="false">
                {c} ({count})
              </button>
            );
          })
        }
      </div>

      <div id="project-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          PROJECTS.map((p) => (
            <a
              href={`/projekt/${p.slug}`}
              data-category={p.category}
              class="project-card group block"
            >
              <div class="aspect-[4/3] bg-[color:var(--color-steel)] rounded-2xl overflow-hidden relative mb-5">
                <img
                  src={p.image.replace('/projekt/', '/projekt/thumb/')}
                  alt={p.imageAlt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/5 to-transparent"></div>
                <div class="absolute top-4 left-4">
                  <span class="text-[10px] uppercase tracking-[0.14em] bg-white/15 backdrop-blur-md text-white px-3 py-1 rounded-full font-semibold">
                    {p.category}
                  </span>
                </div>
                <div class="absolute bottom-4 left-4 right-4 text-white">
                  <p class="text-[11px] uppercase tracking-[0.14em] text-white/70 font-semibold">{p.client}</p>
                  <p class="text-xs text-white/50 mt-0.5">{p.period}</p>
                </div>
              </div>
              <div class="flex items-baseline justify-between gap-3 mb-2">
                <h3 class="text-lg font-semibold tracking-tight group-hover:text-[color:var(--color-brand-red)] transition-colors">
                  {p.title}
                </h3>
                {p.volume && (
                  <span class="text-xs font-semibold text-[color:var(--color-brand-red)] whitespace-nowrap tabular-nums">{p.volume}</span>
                )}
              </div>
              <p class="text-sm text-[color:var(--color-ink-60)]">{p.type}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLAnchorElement>(".project-card");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => {
        b.classList.remove("active", "bg-[color:var(--color-ink)]", "text-white");
        b.classList.add("bg-[color:var(--color-paper-2)]", "text-[color:var(--color-ink)]");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active", "bg-[color:var(--color-ink)]", "text-white");
      btn.classList.remove("bg-[color:var(--color-paper-2)]", "text-[color:var(--color-ink)]");
      btn.setAttribute("aria-selected", "true");

      cards.forEach((card) => {
        const cat = card.dataset.category;
        if (filter === "all" || cat === filter) {
          card.classList.remove("hidden");
        } else {
          card.classList.add("hidden");
        }
      });
    });
  });
</script>
