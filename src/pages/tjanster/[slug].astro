---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { SERVICES, PROJECTS, SITE } from "../../lib/site";

export function getStaticPaths() {
  return Object.values(SERVICES).map((s) => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

const { service } = Astro.props;

const relatedProjects = PROJECTS.filter((p) =>
  p.category.toLowerCase().includes(service.title.split(" ")[0].toLowerCase())
).slice(0, 3);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: service.title,
  provider: { "@id": `${SITE.url}/#organization` },
  areaServed: "Stockholm",
  description: service.long,
  url: `${SITE.url}/tjanster/${service.slug}`,
};
---

<BaseLayout
  title={service.title}
  description={service.long.slice(0, 155)}
  schema={serviceSchema}
>
  <article>
    <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <nav class="text-xs text-[color:var(--color-ink-40)] mb-8" aria-label="Brödsmulor">
          <a href="/" class="hover:text-[color:var(--color-brand-red)]">Hem</a>
          <span class="mx-2">/</span>
          <a href="/tjanster" class="hover:text-[color:var(--color-brand-red)]">Tjänster</a>
          <span class="mx-2">/</span>
          <span>{service.title}</span>
        </nav>

        <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
          {service.title}
        </h1>
        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
          {service.long}
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20 bg-[color:var(--color-paper-2)]">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Det här gör vi</h2>
        <ul class="grid md:grid-cols-2 gap-4 max-w-4xl">
          {
            service.bullets.map((b) => (
              <li class="flex items-start gap-3 text-lg">
                <svg width="22" height="22" viewBox="0 0 20 20" fill="none" class="mt-1 flex-shrink-0 text-[color:var(--color-brand-red)]" aria-hidden="true">
                  <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.25"/>
                  <path d="M6 10.5l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="leading-relaxed">{b}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {relatedProjects.length > 0 && (
      <section class="py-20 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
          <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Relaterade projekt</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
              relatedProjects.map((p) => (
                <a href={`/projekt/${p.slug}`} class="group block p-8 bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
                  <p class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] group-hover:text-white/40 mb-4">
                    {p.client}
                  </p>
                  <h3 class="text-xl font-semibold mb-3 group-hover:text-[color:var(--color-brand-red)] transition-colors">
                    {p.title}
                  </h3>
                  <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed line-clamp-3 mb-4">
                    {p.summary}
                  </p>
                  <p class="text-sm font-semibold text-[color:var(--color-brand-red)]">{p.volume}</p>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    )}

    <CTA />
  </article>
</BaseLayout>
