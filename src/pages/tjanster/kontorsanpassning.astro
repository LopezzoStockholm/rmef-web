---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { SITE } from "../../lib/site";

const title = "Kontorsanpassning Stockholm – ombyggnad med drift pågående";
const description =
  "Kontorsanpassning i Stockholm. Totalombyggnad av våningsplan med kvarvarande hyresgäst, nya personalrum, kök och moderniserade arbetsytor. Referens: Axfoods huvudkontor.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      serviceType: "Kontorsanpassning",
      provider: { "@id": `${SITE.url}/#organization` },
      areaServed: ["Stockholm", "Stockholms län", "Mälardalen"],
      description:
        "Totalentreprenad för kontorsanpassning med kvarvarande hyresgäst. Samordning, etappläggning och leverans utan driftstörning.",
      url: `${SITE.url}/tjanster/kontorsanpassning`,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Hem", item: SITE.url },
        { "@type": "ListItem", position: 2, name: "Tjänster", item: `${SITE.url}/tjanster` },
        { "@type": "ListItem", position: 3, name: "Ombyggnation", item: `${SITE.url}/tjanster/ombyggnation` },
        { "@type": "ListItem", position: 4, name: "Kontorsanpassning", item: `${SITE.url}/tjanster/kontorsanpassning` },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <article>
    <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <nav class="text-xs text-[color:var(--color-ink-40)] mb-8" aria-label="Brödsmulor">
          <a href="/" class="hover:text-[color:var(--color-brand-red)]">Hem</a>
          <span class="mx-2">/</span>
          <a href="/tjanster" class="hover:text-[color:var(--color-brand-red)]">Tjänster</a>
          <span class="mx-2">/</span>
          <a href="/tjanster/ombyggnation" class="hover:text-[color:var(--color-brand-red)]">Ombyggnation</a>
          <span class="mx-2">/</span>
          <span>Kontorsanpassning</span>
        </nav>

        <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
          Kontorsanpassning med pågående verksamhet
        </h1>
        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
          Att bygga om ett kontor medan medarbetarna sitter där ställer särskilda krav. Ljud, damm, logistik och arbetsmiljö måste hanteras så att verksamheten inte störs. Vi har gjort det i åratal åt Axfood, Atrium Ljungberg och andra krävande beställare.
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20 bg-[color:var(--color-paper-2)]">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Detta ingår i en typisk kontorsanpassning</h2>
        <ul class="grid md:grid-cols-2 gap-4 max-w-4xl">
          {[
            "Rivning av väggar och ytskikt",
            "Ny planlösning enligt arkitektritningar",
            "Nya personalkök och wc-grupper",
            "Omklädningsrum och vilorum",
            "Elinstallation och belysning",
            "Ventilation och klimatanläggning",
            "Golv, väggar och tak",
            "Fast inredning och möbleringsritning",
            "Brand- och tillgänglighets­anpassning",
            "Städ, slutbesiktning och överlämning",
          ].map((b) => (
            <li class="flex items-start gap-3 text-lg">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" class="mt-1 flex-shrink-0 text-[color:var(--color-brand-red)]" aria-hidden="true">
                <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.25"/>
                <path d="M6 10.5l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="leading-relaxed">{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-20 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="grid lg:grid-cols-2 gap-16">
          <div>
            <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-8">Så hanterar vi drift-kravet</h2>
            <div class="space-y-6 text-lg text-[color:var(--color-ink-60)] leading-relaxed">
              <p>
                För kvarvarande hyresgäster är det tre saker som spelar roll: ljud, damm och logistik. Vi tar dem en i taget.
              </p>
              <p>
                <strong class="text-[color:var(--color-ink)]">Ljud:</strong> De bullrande arbetsmomenten (rivning, borrning, golvslipning) schemaläggs utanför kontorstid eller flyttas till dagar då hyresgästen inte är där. I zon-indelning hanterar vi att pelare och bjälklag isoleras mot medarbetarkontor.
              </p>
              <p>
                <strong class="text-[color:var(--color-ink)]">Damm:</strong> Arbetsområdet avgränsas med dammluckor och undertrycksventilation. Gemensamma ytor (hissar, trappor, pentryn) städas flera gånger per dag.
              </p>
              <p>
                <strong class="text-[color:var(--color-ink)]">Logistik:</strong> In- och utmaterial tas via nattutrymning eller separat hiss när det är möjligt. Avfall buntas och hämtas utanför kontorstid för att inte blockera entré.
              </p>
            </div>
          </div>
          <div>
            <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-8">Referensprojekt</h2>
            <a href="/projekt/axfood-huvudkontor" class="group block p-8 bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500 mb-4">
              <p class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] group-hover:text-white/40 mb-4">Axfood AB</p>
              <h3 class="text-xl font-semibold mb-3 group-hover:text-[color:var(--color-brand-red)] transition-colors">Axfood huvudkontor</h3>
              <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed mb-4">
                Totalombyggnad av flera våningsplan. 3 000 kvm kontorsanpassning, nya personalkök, wc-grupper och omklädningsrum. Samtliga discipliner i egen regi.
              </p>
              <p class="text-sm font-semibold text-[color:var(--color-brand-red)]">7–25 Mkr per etapp · 2018–2024</p>
            </a>
            <p class="text-sm text-[color:var(--color-ink-60)] italic leading-relaxed">
              "Samtliga arbeten utfördes med kvarvarande hyresgäster i direkt anslutning till arbetsområdet. Krävde minutiös logistik kring nytt material och avfall – inga driftstörningar accepterades."
            </p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </article>
</BaseLayout>
