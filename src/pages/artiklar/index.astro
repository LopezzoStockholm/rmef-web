---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";

const articles = (await getCollection("artiklar")).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);

// Editorial-layout: första (nyaste) som featured, övriga i grid
const [featured, ...rest] = articles;

// Färgkodning per kategori
const categoryColor: Record<string, string> = {
  Kostnad: "bg-[color:var(--color-brand-red)] text-white",
  Upphandling: "bg-[color:var(--color-ink)] text-white",
  Branschinsikt: "bg-[color:var(--color-paper-warm)] text-[color:var(--color-ink)]",
  Teknik: "bg-[color:var(--color-steel)] text-white",
};
---

<BaseLayout
  title="Artiklar och guider"
  description="Branschguider från RM Entreprenad & Fasad. Kostnadsguider, upphandlingsråd och tekniska genomgångar för fastighetsägare, byggherrar och beställare."
>
  <section class="pt-24 lg:pt-32 pb-12 lg:pb-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-brand-red)] font-semibold mb-6">Artiklar och guider</p>
      <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
        Branschinsikt från ett team som bygger i Stockholm varje dag.
      </h1>
      <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
        Guider, kostnadsintervall och upphandlingsråd för fastighetsägare, byggherrar och
        beställare som ska handla upp mark, bygg, el eller fasad.
      </p>
    </div>
  </section>

  {/* Featured artikel, full-width editorial card */}
  {featured && (
    <section class="pb-12 lg:pb-20" data-reveal>
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <a
          href={`/artiklar/${featured.slug}/`}
          class="group grid lg:grid-cols-12 gap-8 lg:gap-12 items-center bg-[color:var(--color-paper-2)] rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-black/10 transition-all duration-500"
        >
          {featured.data.heroImage && (
            <div class="lg:col-span-7 aspect-[16/10] lg:aspect-auto lg:self-stretch overflow-hidden bg-[color:var(--color-steel)] relative">
              {(() => {
                const base = featured.data.heroImage.replace(/\.webp$/, "");
                const thumbSrc = featured.data.heroImage.replace("/projekt/", "/projekt/thumb/");
                return (
                  <img
                    src={thumbSrc}
                    srcset={`${base}-400.webp 400w, ${base}-800.webp 800w, ${base}-1200.webp 1200w, ${featured.data.heroImage} 1600w`}
                    sizes="(max-width: 768px) 100vw, 60vw"
                    alt={featured.data.heroImageAlt ?? featured.data.title}
                    width="1200"
                    height="750"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                );
              })()}
            </div>
          )}
          <div class="lg:col-span-5 p-8 lg:p-12 lg:pr-16">
            <div class="flex items-center gap-3 mb-5">
              <span class={`text-[10px] uppercase tracking-[0.18em] px-3 py-1 rounded-full font-semibold ${categoryColor[featured.data.category] ?? categoryColor.Kostnad}`}>
                Mest läst · {featured.data.category}
              </span>
              {featured.data.readingTime && (
                <span class="text-xs text-[color:var(--color-ink-40)]">
                  {featured.data.readingTime} min läsning
                </span>
              )}
            </div>
            <h2 class="text-2xl lg:text-4xl font-semibold tracking-tight leading-[1.1] mb-5 group-hover:text-[color:var(--color-brand-red)] transition-colors">
              {featured.data.title}
            </h2>
            <p class="text-base lg:text-lg text-[color:var(--color-ink-60)] leading-relaxed mb-8">
              {featured.data.description}
            </p>
            <div class="flex items-center justify-between border-t border-[color:var(--color-ink-10)] pt-6">
              <time class="text-xs text-[color:var(--color-ink-40)] uppercase tracking-wider" datetime={featured.data.published.toISOString()}>
                {featured.data.published.toLocaleDateString("sv-SE", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-[color:var(--color-brand-red)] group-hover:translate-x-1 transition-transform">
                Läs hela guiden
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {/* Övriga artiklar, 3-kolumns grid */}
  <section class="pb-20 lg:pb-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="flex items-center gap-3 mb-10" data-reveal>
        <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-brand-red)]" aria-hidden="true"></span>
        <p class="text-[10px] uppercase tracking-[0.22em] text-[color:var(--color-ink-60)] font-semibold">
          Fler artiklar
        </p>
        <span class="flex-1 h-px bg-[color:var(--color-ink-10)]" aria-hidden="true"></span>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {
          rest.map((a, idx) => (
            <a
              href={`/artiklar/${a.slug}/`}
              class="group block bg-[color:var(--color-paper-2)] rounded-3xl overflow-hidden hover:shadow-xl hover:shadow-black/5 hover:-translate-y-1 transition-all duration-500"
              data-reveal
              style={`transition-delay: ${idx * 80}ms`}
            >
              {a.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden bg-[color:var(--color-steel)] relative">
                  {(() => {
                    const base = a.data.heroImage.replace(/\.webp$/, "");
                    const thumbSrc = a.data.heroImage.replace("/projekt/", "/projekt/thumb/");
                    return (
                      <img
                        src={thumbSrc}
                        srcset={`${base}-400.webp 400w, ${base}-800.webp 800w, ${base}-1200.webp 1200w`}
                        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        alt={a.data.heroImageAlt ?? a.data.title}
                        width="800"
                        height="500"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                      />
                    );
                  })()}
                  <div class="absolute top-4 left-4">
                    <span class={`text-[10px] uppercase tracking-[0.18em] px-3 py-1 rounded-full font-semibold backdrop-blur-sm ${categoryColor[a.data.category] ?? categoryColor.Kostnad}`}>
                      {a.data.category}
                    </span>
                  </div>
                </div>
              )}
              <div class="p-7">
                {a.data.readingTime && (
                  <p class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] font-semibold mb-3">
                    {a.data.readingTime} min läsning
                  </p>
                )}
                <h2 class="text-lg lg:text-xl font-semibold tracking-tight leading-[1.25] mb-3 group-hover:text-[color:var(--color-brand-red)] transition-colors">
                  {a.data.title}
                </h2>
                <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed line-clamp-3 mb-5">
                  {a.data.description}
                </p>
                <div class="flex items-center justify-between border-t border-[color:var(--color-ink-10)] pt-4">
                  <time class="text-[11px] text-[color:var(--color-ink-40)] uppercase tracking-wider" datetime={a.data.published.toISOString()}>
                    {a.data.published.toLocaleDateString("sv-SE", { year: "numeric", month: "short", day: "numeric" })}
                  </time>
                  <span class="text-xs font-semibold text-[color:var(--color-brand-red)] group-hover:translate-x-1 transition-transform">
                    Läs mer →
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
