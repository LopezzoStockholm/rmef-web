---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { SITE } from "../../lib/site";

export async function getStaticPaths() {
  const articles = await getCollection("artiklar");
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.description,
  author: { "@type": "Organization", name: data.author },
  publisher: { "@id": `${SITE.url}/#organization` },
  datePublished: data.published.toISOString(),
  ...(data.updated && { dateModified: data.updated.toISOString() }),
  image: data.heroImage ? `${SITE.url}${data.heroImage}` : undefined,
  articleSection: data.category,
  keywords: data.tags.join(", "),
  mainEntityOfPage: `${SITE.url}/artiklar/${article.slug}/`,
  inLanguage: "sv-SE",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Artiklar", item: `${SITE.url}/artiklar/` },
    { "@type": "ListItem", position: 3, name: data.title, item: `${SITE.url}/artiklar/${article.slug}/` },
  ],
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.heroImage}
  schema={[articleSchema, breadcrumbSchema]}
>
  <article class="pt-24 lg:pt-32 pb-20">
    <header class="mx-auto max-w-3xl px-6 lg:px-10 mb-10">
      <nav class="text-xs text-[color:var(--color-ink-40)] mb-8" aria-label="Brödsmulor">
        <a href="/" class="hover:text-[color:var(--color-brand-red)]">Hem</a>
        <span class="mx-2">/</span>
        <a href="/artiklar" class="hover:text-[color:var(--color-brand-red)]">Artiklar</a>
        <span class="mx-2">/</span>
        <span>{data.title}</span>
      </nav>

      <div class="flex items-center gap-3 mb-6">
        <span class="text-[10px] uppercase tracking-[0.18em] bg-[color:var(--color-brand-red)] text-white px-3 py-1.5 rounded-full font-semibold">
          {data.category}
        </span>
        {data.readingTime && (
          <span class="text-xs text-[color:var(--color-ink-40)]">{data.readingTime} min läsning</span>
        )}
      </div>

      <h1 class="text-[length:var(--text-display)] font-semibold leading-[1.05] tracking-tight mb-6">
        {data.title}
      </h1>

      <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed mb-8">
        {data.description}
      </p>

      <div class="flex items-center gap-4 pt-6 border-t border-[color:var(--color-ink-10)] text-sm text-[color:var(--color-ink-60)]">
        <span>{data.author}</span>
        <span class="text-[color:var(--color-ink-40)]">·</span>
        <time datetime={data.published.toISOString()}>
          {data.published.toLocaleDateString("sv-SE", { year: "numeric", month: "long", day: "numeric" })}
        </time>
      </div>
    </header>

    {data.heroImage && (
      <div class="mx-auto max-w-5xl px-6 lg:px-10 mb-12">
        <div class="aspect-[16/9] rounded-3xl overflow-hidden bg-[color:var(--color-steel)]">
          <img
            src={data.heroImage}
            alt={data.heroImageAlt ?? data.title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}

    <div class="mx-auto max-w-3xl px-6 lg:px-10 prose prose-lg prose-neutral">
      <Content />
    </div>

    {data.tags.length > 0 && (
      <div class="mx-auto max-w-3xl px-6 lg:px-10 mt-12 pt-8 border-t border-[color:var(--color-ink-10)]">
        <p class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-ink-40)] font-semibold mb-4">Taggar</p>
        <div class="flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="text-xs bg-[color:var(--color-paper-2)] text-[color:var(--color-ink-60)] px-3 py-1.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </article>

  <CTA />
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .prose h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    color: var(--color-ink);
    line-height: 1.75;
    margin: 0 0 1.25rem;
    font-size: 1.05rem;
  }
  .prose ul, .prose ol {
    margin: 1rem 0 1.5rem;
    padding-left: 1.25rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
    line-height: 1.65;
  }
  .prose ul li::marker {
    color: var(--color-brand-red);
  }
  .prose a {
    color: var(--color-brand-red);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose strong {
    font-weight: 600;
    color: var(--color-ink);
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .prose th, .prose td {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-ink-10);
  }
  .prose th {
    font-weight: 600;
    background: var(--color-paper-2);
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--color-ink-10);
    margin: 2rem 0;
  }
  .prose input[type="checkbox"] {
    margin-right: 0.5rem;
  }
</style>
