---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";
const msg = encodeURIComponent("Hej! Jag är intresserad av att diskutera ett projekt.");
const waLink = `https://wa.me/${SITE.whatsapp.replace(/\D/g, "")}?text=${msg}`;

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Kontakt — RM Entreprenad & Fasad AB",
  url: `${SITE.url}/kontakt`,
};
---

<BaseLayout
  title="Kontakt"
  description="Kontakta RM Entreprenad & Fasad AB — ring, mejla, chatta via WhatsApp eller skicka projektförfrågan via formuläret. Vi svarar samma dag."
  schema={contactSchema}
>
  <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-6">Kontakt</p>
      <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
        Ring. Mejla. Chatta. Vi svarar samma dag.
      </h1>
      <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
        Välj den kanal som passar dig. Alla vägar leder till samma team — ingen kundtjänstring,
        ingen ärendekö.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="grid lg:grid-cols-3 gap-6 mb-12">
        <a href={`tel:${SITE.phoneDisplay.replace(/\s/g, "")}`} class="group p-8 bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-brand-red)] mb-6" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          <h2 class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] group-hover:text-white/40 mb-2">Ring direkt</h2>
          <p class="text-2xl lg:text-3xl font-semibold tracking-tight">{SITE.phoneDisplay}</p>
        </a>

        <a href={`mailto:${SITE.email}`} class="group p-8 bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-brand-red)] mb-6" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 7l-10 6L2 7"/>
          </svg>
          <h2 class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] group-hover:text-white/40 mb-2">Mejla oss</h2>
          <p class="text-2xl lg:text-3xl font-semibold tracking-tight">{SITE.email}</p>
        </a>

        <a href={waLink} target="_blank" rel="noopener" class="group p-8 bg-[#25D366] text-white rounded-2xl hover:opacity-90 transition-opacity">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="mb-6" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <h2 class="text-xs uppercase tracking-wider text-white/60 mb-2">Chatta med oss</h2>
          <p class="text-2xl lg:text-3xl font-semibold tracking-tight">WhatsApp</p>
        </a>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 bg-[color:var(--color-paper-2)] rounded-3xl p-8 lg:p-12">
        <div>
          <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mb-6">Skicka projektförfrågan</h2>
          <p class="text-[color:var(--color-ink-60)] leading-relaxed mb-8">
            Beskriv ert projekt så kontaktar vi er inom 24 timmar. Bifoga gärna underlag, ritningar eller kravbild.
          </p>
          <form
            id="contact-form"
            name="kontakt"
            method="POST"
            action="/api/contact"
            class="space-y-4"
            novalidate
          >
            <input type="text" name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />
            <div class="grid sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Namn</span>
                <input required type="text" name="namn" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)]" />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Företag</span>
                <input type="text" name="foretag" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)]" />
              </label>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">E-post</span>
                <input required type="email" name="email" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)]" />
              </label>
              <label class="block">
                <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Telefon</span>
                <input type="tel" name="telefon" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)]" />
              </label>
            </div>
            <label class="block">
              <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Typ av projekt</span>
              <select name="typ" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)]">
                <option>Mark & anläggning</option>
                <option>Bygg / Totalentreprenad</option>
                <option>El</option>
                <option>Fasad</option>
                <option>Annat</option>
              </select>
            </label>
            <label class="block">
              <span class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Beskriv ert projekt</span>
              <textarea required name="meddelande" rows="5" class="mt-1 w-full bg-[color:var(--color-paper)] border border-[color:var(--color-ink-10)] rounded-lg px-4 py-3 focus:outline-none focus:border-[color:var(--color-brand-red)] resize-none"></textarea>
            </label>
            <button type="submit" id="contact-submit" class="w-full bg-[color:var(--color-ink)] text-white px-6 py-3.5 rounded-full text-sm font-semibold hover:bg-[color:var(--color-brand-red)] transition-colors disabled:opacity-60">
              Skicka förfrågan
            </button>
            <p id="contact-status" class="text-sm text-center text-[color:var(--color-ink-60)] min-h-[1.25rem]" aria-live="polite"></p>
          </form>

          <script is:inline>
            (() => {
              const form = document.getElementById('contact-form');
              const btn = document.getElementById('contact-submit');
              const status = document.getElementById('contact-status');
              if (!form || !btn || !status) return;
              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                btn.disabled = true;
                status.textContent = 'Skickar…';
                status.style.color = '';
                const data = Object.fromEntries(new FormData(form));
                try {
                  const resp = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'content-type': 'application/json' },
                    body: JSON.stringify(data),
                  });
                  const j = await resp.json().catch(() => ({}));
                  if (resp.ok && j.ok) {
                    status.textContent = 'Tack! Vi hör av oss inom 24 timmar.';
                    status.style.color = '#2E7D32';
                    form.reset();
                  } else {
                    status.textContent = 'Något gick fel — ring oss eller mejla info@rmef.se istället.';
                    status.style.color = '#C8381F';
                    btn.disabled = false;
                  }
                } catch {
                  status.textContent = 'Nätverksfel — ring oss eller mejla info@rmef.se.';
                  status.style.color = '#C8381F';
                  btn.disabled = false;
                }
              });
            })();
          </script>
        </div>

        <div>
          <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mb-6">Hitta oss</h2>
          <div class="bg-[color:var(--color-paper)] rounded-2xl overflow-hidden border border-[color:var(--color-ink-10)] mb-6">
            <iframe
              title="Karta över RM Entreprenad & Fasad kontor"
              src={SITE.googleMapsEmbed}
              width="100%"
              height="360"
              style="border:0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <dl class="space-y-4">
            <div>
              <dt class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Organisation</dt>
              <dd class="text-base">{SITE.name}</dd>
              <dd class="text-sm text-[color:var(--color-ink-60)]">Org.nr {SITE.orgNumber}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] font-semibold">Besöksadress</dt>
              <dd class="text-base">{SITE.address.city}, Sverige</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
