---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import { SITE } from "../lib/site";

const title = "För bostadsrättsföreningar – skyddsrum, fasad och betong";
const description =
  "Vi arbetar med bostadsrättsföreningar i Stockholm och Mälardalen – från MSB-åtgärd av skyddsrum till fasadrenovering, balkongrenovering och totalentreprenad.";

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Hem", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "För BRF", item: `${SITE.url}/for-brf` },
  ],
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <article>
    <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-6">För bostadsrättsföreningar</p>
        <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
          Trygg entreprenör för styrelsens tyngre beslut
        </h1>
        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
          Styrelsen i en BRF fattar återkommande beslut som påverkar budget och medlemmarnas vardag: skyddsrumsåtgärder, fasadrenovering, balkonger, stambyte. Vi levererar med fast pris, tydlig dokumentation och projektledare genom hela processen.
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20 bg-[color:var(--color-paper-2)]">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Tjänster för BRF</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="/tjanster/skyddsrum" class="group block p-8 bg-white rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
            <h3 class="text-2xl font-semibold mb-4 group-hover:text-[color:var(--color-brand-red)] transition-colors">Skyddsrum</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed">MSB-åtgärd, sanering, besiktning. Vi hanterar hela processen från protokoll till godkänd status.</p>
          </a>
          <a href="/tjanster/fasad" class="group block p-8 bg-white rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
            <h3 class="text-2xl font-semibold mb-4 group-hover:text-[color:var(--color-brand-red)] transition-colors">Fasadrenovering</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed">Omputsning, tilläggsisolering och antikvariska restaureringar för BRF i Stockholm och Mälardalen.</p>
          </a>
          <a href="/tjanster/balkongrenovering" class="group block p-8 bg-white rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
            <h3 class="text-2xl font-semibold mb-4 group-hover:text-[color:var(--color-brand-red)] transition-colors">Balkongrenovering</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed">Karbonatiserad betong, armeringskorrosion, räckesbyten och tätskikt – samordnat med övrig renovering.</p>
          </a>
          <a href="/tjanster/betongrenovering" class="group block p-8 bg-white rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
            <h3 class="text-2xl font-semibold mb-4 group-hover:text-[color:var(--color-brand-red)] transition-colors">Betongrenovering</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed">Bjälklag, pelare, betongfasad och källare. Åtgärd mot karbonatisering och armeringskorrosion.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Så fungerar ett BRF-projekt hos oss</h2>
        <ol class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <li class="relative">
            <span class="text-5xl font-semibold text-[color:var(--color-brand-red)] leading-none block mb-6">01</span>
            <h3 class="text-lg font-semibold mb-3">Platsbesök och bedömning</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Vi kommer på plats, går igenom nuläget med styrelsen och dokumenterar vad som behöver göras.</p>
          </li>
          <li class="relative">
            <span class="text-5xl font-semibold text-[color:var(--color-brand-red)] leading-none block mb-6">02</span>
            <h3 class="text-lg font-semibold mb-3">Fastprisoffert</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Skriftlig offert med fast pris, vad som ingår, tidsplan och villkor. Ingen ÄTA-överraskning.</p>
          </li>
          <li class="relative">
            <span class="text-5xl font-semibold text-[color:var(--color-brand-red)] leading-none block mb-6">03</span>
            <h3 class="text-lg font-semibold mb-3">Projektering och stämma</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Vi hjälper till med underlag för extrastämma vid behov. Ritningar, materialval och tidsplan klart innan start.</p>
          </li>
          <li class="relative">
            <span class="text-5xl font-semibold text-[color:var(--color-brand-red)] leading-none block mb-6">04</span>
            <h3 class="text-lg font-semibold mb-3">Utförande och överlämning</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Projektledare på plats, veckovisa uppdateringar till styrelsen, slutbesiktning och komplett dokumentation.</p>
          </li>
        </ol>
      </div>
    </section>

    <CTA />
  </article>
</BaseLayout>
