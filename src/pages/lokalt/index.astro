---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { LOCATIONS } from "../../lib/locations";

const byService = LOCATIONS.reduce<Record<string, typeof LOCATIONS>>((acc, loc) => {
  (acc[loc.serviceLabel] ??= []).push(loc);
  return acc;
}, {});
---

<BaseLayout
  title="Lokalt, fasadrenovering, skyddsrum och totalentreprenad i Stockholm och Mälardalen"
  description="RM Entreprenad & Fasad arbetar i hela Stockholms län och Mälardalen. Välj ort för mer information om fasadrenovering, skyddsrum, betongrenovering och totalentreprenad."
>
  <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-6">Lokalt</p>
      <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
        Stockholm och Mälardalen, med egen projektledning.
      </h1>
      <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
        Vi har kontor i Stockholm och arbetar i hela Stockholms län, Uppland och Mälardalen.
        Välj din ort nedan för lokal information, referensprojekt och snabb kontakt.
      </p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10 space-y-12">
      {Object.entries(byService).map(([svc, locs]) => (
        <div>
          <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-8">{svc}</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {locs.map((loc) => (
              <a href={`/lokalt/${loc.slug}`} class="group block p-8 bg-[color:var(--color-paper-2)] rounded-2xl hover:bg-[color:var(--color-ink)] hover:text-white transition-all duration-500">
                <p class="text-xs uppercase tracking-wider text-[color:var(--color-ink-40)] group-hover:text-white/40 mb-4">{loc.serviceLabel}</p>
                <h3 class="text-2xl font-semibold mb-3 group-hover:text-[color:var(--color-brand-red)] transition-colors">{loc.ort}</h3>
                <p class="text-sm text-[color:var(--color-ink-60)] group-hover:text-white/60 leading-relaxed line-clamp-3">{loc.description}</p>
                <span class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-[color:var(--color-brand-red)] group-hover:text-white">
                  Läs mer
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
