---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ClientLogos from "../components/ClientLogos.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import Process from "../components/Process.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import { SITE } from "../lib/site";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Vilka projektvolymer tar RM Entreprenad & Fasad?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Totalentreprenader och utförandeentreprenader från ca 3 Mkr upp till 75+ Mkr. Största genomförda projekt är grundläggning åt Stockholmshem på 75 Mkr. Minsta typiska uppdrag är fasad- eller restaureringsprojekt runt 3 Mkr.",
      },
    },
    {
      "@type": "Question",
      name: "Vilka kunder arbetar ni med?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Vi arbetar B2B med professionella beställare: fastighetsägare (Stockholmshem, Atrium Ljungberg, Axfood), generalentreprenörer (Skanska), regionala fastighetsbolag (Locum), kommuner (Lidingö, Sigtuna, Knivsta) och byggherrar (Habitek, Patriam).",
      },
    },
    {
      "@type": "Question",
      name: "Vilka entreprenadformer använder ni?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Vi driver totalentreprenader enligt ABT 06 och utförandeentreprenader enligt AB 04. Varje projekt har en dokumenterad KMA-plan. Vi är F-skatt-registrerade och har ansvarsförsäkring.",
      },
    },
    {
      "@type": "Question",
      name: "Arbetar ni utanför Stockholm?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Kontor i Stockholm med projekt i Mälardalen — Stockholm, Lidingö, Sigtuna, Knivsta, Norrtälje, Sollentuna, Danderyd. Större uppdrag kan tas utanför regionen.",
      },
    },
    {
      "@type": "Question",
      name: "Hur snabbt kan ni starta ett projekt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Efter godkänd offert kan vi vanligen starta inom 4–8 veckor, beroende på projektets storlek och bemanningsbehov. Akuta insatser hanteras snabbare.",
      },
    },
    {
      "@type": "Question",
      name: "Har ni egen personal eller använder ni underentreprenörer?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Båda. Kärnkompetens in-house inom bygg, mark och el, plus ett brett nätverk av kvalitetssäkrade underentreprenörer. Det gör att vi kan anpassa bemanningen exakt efter projektet.",
      },
    },
  ],
};
---

<BaseLayout
  title={SITE.defaultTitle}
  description={SITE.defaultDescription}
  schema={faqSchema}
>
  <Hero />
  <ClientLogos />
  <ServicesGrid />
  <FeaturedProjects />
  <Process />
  <Testimonials />
  <CTA />
</BaseLayout>
