---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const title = "För kommuner — upphandling, referenser och ramavtal";
const description =
  "RM Entreprenad & Fasad är etablerad leverantör till kommuner i Stockholms län och Mälardalen. Referens: Lidingö Stad, Sigtuna kommun, Knivsta kommun, Solna Stad.";
---

<BaseLayout title={title} description={description}>
  <article>
    <section class="pt-24 lg:pt-32 pb-12 lg:pb-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <p class="text-xs uppercase tracking-wider text-[color:var(--color-brand-red)] font-semibold mb-6">För kommuner</p>
        <h1 class="text-[length:var(--text-display)] font-semibold leading-[1] tracking-tight max-w-4xl mb-8">
          Erfaren leverantör till kommunal sektor
        </h1>
        <p class="text-lg lg:text-xl text-[color:var(--color-ink-60)] leading-relaxed max-w-3xl">
          Vi levererar totalentreprenader, utförandeentreprenader och specialuppdrag åt kommuner i Stockholms län och Mälardalen. Lidingö Stad, Sigtuna kommun, Knivsta kommun och Solna Stad är återkommande beställare.
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20 bg-[color:var(--color-paper-2)]">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">Vad vi levererar</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-8 bg-white rounded-2xl">
            <h3 class="text-xl font-semibold mb-3">Antikvariska restaureringar</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Referensprojekt: Vindarnas tempel och Kaptensstugan åt Lidingö Stad. K-märkta byggnader med full antikvarisk kontroll.</p>
          </div>
          <div class="p-8 bg-white rounded-2xl">
            <h3 class="text-xl font-semibold mb-3">Skol- och institutionsbygg</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Engelska skolan Sigtuna och Raul Wallenbergskolan Bagartorp. Markanläggning och infrastruktur kring skolbyggnation.</p>
          </div>
          <div class="p-8 bg-white rounded-2xl">
            <h3 class="text-xl font-semibold mb-3">Kommunal infrastruktur</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Ledningsomläggning Knivsta. Mark- och VA-arbeten i samordning med kommunens drifts­organisation.</p>
          </div>
          <div class="p-8 bg-white rounded-2xl">
            <h3 class="text-xl font-semibold mb-3">Allmännytta</h3>
            <p class="text-sm text-[color:var(--color-ink-60)] leading-relaxed">Ramavtal med Signalisten i Solna som strategisk partner till Rocmore. Fasadrenovering, grundläggning och finplanering.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <h2 class="text-[length:var(--text-h2)] font-semibold tracking-tight mb-10">LOU och upphandling</h2>
        <div class="grid lg:grid-cols-2 gap-16 max-w-5xl">
          <div class="space-y-6 text-lg text-[color:var(--color-ink-60)] leading-relaxed">
            <p>
              Vi är F-skatt-registrerade, momsregistrerade och har ansvarsförsäkring hos Trygg Hansa.
              Samtliga handlingar som krävs vid offentlig upphandling kan levereras på begäran.
            </p>
            <p>
              Vårt kärnteam har genomfört upphandlingar enligt LOU flera gånger och förstår processens krav på dokumentation, referensarbeten, finansiell stabilitet och miljökrav.
            </p>
          </div>
          <div class="bg-[color:var(--color-paper-2)] rounded-2xl p-8">
            <h3 class="font-semibold mb-4">Standarddokument vid upphandling</h3>
            <ul class="space-y-3 text-sm text-[color:var(--color-ink-60)]">
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Registerutdrag och F-skatt</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Ansvarsförsäkring</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Finansiell kreditbedömning</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Referensprojekt med kontaktpersoner</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>KMA-plan</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Arbetsmiljöpolicy</li>
              <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand-red)] font-semibold">·</span>Hållbarhetspolicy</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </article>
</BaseLayout>
