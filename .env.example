# Kopiera till .env innan deploy och fyll i värden

# Cloudflare Web Analytics (gratis, cookieless, GDPR-vänlig)
# Skapa token: https://dash.cloudflare.com/ → Analytics & Logs → Web Analytics → Add a site
PUBLIC_CF_ANALYTICS_TOKEN=

# Google Tag Manager container (en enda tag hanterar GA4, Meta Pixel, Google Ads, LinkedIn Insight)
# Skapa gratis: https://tagmanager.google.com → konto → container → webb
PUBLIC_GTM_ID=GTM-XXXXXXX
